{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string" },
        "codename": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" },
        "favoriteCardgameId": { "type": "string" },
        "vip": { "type": "boolean" },
        "fighterTags": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "store"] },
        "gender": { "type": "string" },
        "birthDate": { "type": "string" },
        "phone": { "type": "string" },
        "smsVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username"]
    },
    "Product": {
      "title": "Product",
      "description": "TCG Product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "gameId": { "type": "string" },
        "productType": { "type": "string" },
        "imageUrl": { "type": "string" },
        "releaseDate": { "type": "string" },
        "msrp": { "type": "number" },
        "beautyName": { "type": "string" },
        "prerelease": { "type": "boolean" },
        "extLink": { "type": "string" }
      },
      "required": ["name", "slug", "productType"]
    },
    "Store": {
      "title": "Store",
      "description": "Store profile and settings",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "estado": { "type": "string" },
        "cidade": { "type": "string" },
        "bairro": { "type": "string" },
        "endereco": { "type": "string" },
        "zona": { "type": "string" },
        "logo": { "type": "string" },
        "site": { "type": "string" },
        "parceiro": { "type": "boolean" },
        "contato": { "type": "object" },
        "redesSociais": { "type": "object" },
        "vendaHabilitada": { "type": "boolean" }
      },
      "required": ["name", "slug", "ownerUid"]
    },
    "UserCard": {
      "title": "UserCard",
      "description": "A card in a user's collection or list",
      "type": "object",
      "properties": {
        "game": { "type": "string" },
        "cardId": { "type": "string" },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "quantidade": { "type": "number" },
        "raridade": { "type": "string" },
        "condition": { "type": "string" }
      },
      "required": ["game", "cardId", "name", "quantidade"]
    },
    "Binder": {
      "title": "Binder",
      "description": "A custom card binder",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "gameId": { "type": "string" },
        "gameName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "gameId"]
    },
    "Deck": {
      "title": "Deck",
      "description": "A user-created deck",
      "type": "object",
      "properties": {
        "game": { "type": "string" },
        "name": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "data": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["game", "name", "data"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase order",
      "type": "object",
      "properties": {
        "externalReference": { "type": "string" },
        "buyerUid": { "type": "string" },
        "storeId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "canceled", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array" }
      },
      "required": ["buyerUid", "storeId", "amount", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" },
        "url": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "isRead"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "TCG Tournament event",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "gameId": { "type": "string" },
        "formatId": { "type": "string" },
        "maxPlayers": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "createdBy": { "type": "string" },
        "ticket": { "type": "string" },
        "filledSpots": { "type": "number" }
      },
      "required": ["name", "gameId", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "users/{userId}/cards": {
      "schema": { "$ref": "UserCard" },
      "description": "User card collection"
    },
    "users/{userId}/wishlist": {
      "schema": { "$ref": "UserCard" },
      "description": "User wishlist"
    },
    "users/{userId}/offerlist": {
      "schema": { "$ref": "UserCard" },
      "description": "User offerlist (trade list)"
    },
    "users/{userId}/binders": {
      "schema": { "$ref": "Binder" },
      "description": "User custom binders"
    },
    "users/{userId}/binders/{binderId}/cards": {
      "schema": { "$ref": "UserCard" },
      "description": "Cards inside a custom binder"
    },
    "users/{userId}/decks": {
      "schema": { "$ref": "Deck" },
      "description": "User decks"
    },
    "users/{userId}/notifications": {
      "schema": { "$ref": "Notification" },
      "description": "User notifications"
    },
    "products": {
      "schema": { "$ref": "Product" },
      "description": "Global product database"
    },
    "stores": {
      "schema": { "$ref": "Store" },
      "description": "Store profiles"
    },
    "orders": {
      "schema": { "$ref": "Order" },
      "description": "Purchase orders"
    },
    "tournaments": {
      "schema": { "$ref": "Tournament" },
      "description": "Tournament events"
    }
  }
}
